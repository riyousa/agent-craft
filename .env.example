# Compose-level overrides (optional). Copy to .env in repo root if you want to change defaults.
# Application secrets still live in agent-api/.env (see agent-api/.env.example).

# Host port mappings
AGENT_API_PORT=8000
AGENT_PAGE_PORT=3000
POSTGRES_PORT=5432

# Frontend build-arg — leave empty to have the SPA use relative URLs (nginx proxies to backend).
# Set to an absolute URL only if the frontend is served from a different origin than the backend.
REACT_APP_API_URL=

# Postgres (only used with `--profile postgres`)
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=system_agent
