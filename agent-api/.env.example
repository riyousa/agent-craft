# =============================================================
# LLM Bootstrap (一次性引导，仅用于首次启动种子)
# =============================================================
# 系统启动时若 llm_models 数据表为空，且这两个变量已设置，
# 会自动种子一条默认的 Doubao 模型记录到数据库（api_key 字段
# 引用 ${LLM_API_KEY} 占位符，密钥仍留在环境变量中）。
#
# 之后所有模型的增删改、API Key 轮换都在「全局管理 → 模型管理」
# 的 Web 界面里完成；运行时 LLM 调用全部从数据库 llm_models
# 表读取配置，不再硬编码读取这两个 env 变量。
#
# 如果你打算从 Web 界面直接添加模型（推荐），可以不配这两项。
# =============================================================
LLM_API_KEY=your_api_key_here
# 默认 provider 是火山引擎 Doubao（兼容 OpenAI API）
# 如需用 OpenAI / Qwen / GLM / Gemini 等其他 provider，
# 跳过此处直接在 Web 界面添加。
LLM_MODEL=Doubao2.0-thinking-pro

# =============================================================
# Database Configuration
# =============================================================
# 方式一: SQLite (默认，无需配置)
# 默认使用 agent-api/data/agent.db，开箱即用
# DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# 方式二: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/system_agent

# LangGraph Checkpointer
# "sqlite" (默认) 或 "postgres"
# 如果 DATABASE_URL 使用 PostgreSQL，会自动切换为 postgres checkpointer
# CHECKPOINTER_TYPE=sqlite
# CHECKPOINT_DATABASE_URL=  # 留空则使用 DATABASE_URL
# =============================================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Security Jwt
SECRET_KEY=your_secret_key_here

# =============================================================
# LangSmith Observability (可选)
# =============================================================
# 启用后所有 LangChain/LangGraph 调用自动上报追踪数据
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=agent-craft
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # 默认值，一般无需修改
